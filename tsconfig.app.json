{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    // path alias
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@game-hub/*": ["./src/apps/game-hub/*"],
      "@home-inventory/*": ["./src/apps/home-inventory/*"],
      "@quizzes/*": ["./src/apps/quizzes/*"],
      "@product-list/*": ["./src/apps/product-list//*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js", "src/**/*.jsx"], // Added JS/JSX here
  "exclude": ["node_modules"] // Removed JS/JSX from here
}
